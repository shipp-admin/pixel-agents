# Port for the relay server (default: 5175)
PORT=5175

# Host to bind to (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Authentication token for WebSocket connections.
# If set, clients must connect with ?token=<RELAY_TOKEN> in the WebSocket URL.
# If empty, all connections are allowed (suitable for local dev only).
RELAY_TOKEN=your-secret-token-here

# Directory service (optional)
# URL of the Cloudflare Workers directory (e.g., https://pixel-agents-directory.your-worker.workers.dev)
DIRECTORY_URL=

# Token to authenticate with the directory service
DIRECTORY_TOKEN=

# Public WebSocket URL of THIS relay (e.g., wss://your-tunnel.trycloudflare.com)
# Set this to register with the directory so others can find your office
RELAY_PUBLIC_URL=

# Human-readable name for your office shown in the directory
RELAY_NAME=My Pixel Office

# Stable ID for this relay instance (auto-generated if not set)
RELAY_ID=my-relay-id
