{
  "name": "shipp-agent-hq",
  "version": "1.0.2",
  "description": "Watch your AI agents work in real-time — a live pixel-art office visualizer for Claude Code sessions",
  "bin": {
    "shipp-agent-hq": "./bin/agenthq.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
